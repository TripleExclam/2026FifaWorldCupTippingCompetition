ADMIN_TOKEN=replace-with-a-long-random-admin-token
ADMIN_COOKIE_SECRET=replace-with-a-different-long-random-cookie-secret
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_TTL_SECONDS=86400
WCT_DATA_DIR=/var/lib/world-cup-tipping/data
WCT_ALLOWED_HOSTS=tipping.example.com,localhost,127.0.0.1
WCT_ENABLE_HSTS=true
